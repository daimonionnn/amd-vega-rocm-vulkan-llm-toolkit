FROM rocm/dev-ubuntu-22.04:6.3.4 AS rocm6-libs
# Install rocblas in the 6.3.4 stage so the library files are present to copy
RUN apt-get update -qq && \
    apt-get install -y -qq --no-install-recommends rocblas && \
    rm -rf /var/lib/apt/lists/*

# ─────────────────────────────────────────────────────────────────────────────
#  llama.cpp  ·  ROCm 7.2  ·  AMD Vega 8 iGPU  (gfx902 / gfx909 / gfx90c)
# ─────────────────────────────────────────────────────────────────────────────
#
#  EXPERIMENTAL — ROCm 7.x officially dropped gfx900-family support.
#  This Dockerfile reinstates it by backporting gfx900 tensile libraries
#  from ROCm 6.3.4 (multi-stage) into the ROCm 7.2 rocBLAS install, mirroring
#  the technique used by garymathews/frigate:440056a-rocm-7.2.0.
#
#  Build:  docker build -t llama-rocm7-vega -f build/Dockerfile.rocm7-vega build/
#  Run:    ./run/run-docker-rocm7.sh /path/to/model.gguf
#
# ─────────────────────────────────────────────────────────────────────────────

FROM rocm/dev-ubuntu-22.04:7.2
RUN apt-get update -qq && \
    apt-get install -y -qq --no-install-recommends \
      build-essential \
      cmake \
      git \
      curl \
      wget \
      python3 \
      libomp-dev \
      hipblas-dev \
      rocblas-dev \
      rocsolver-dev \
      numactl \
      software-properties-common \
      gnupg2 \
      dpkg-dev && \
    rm -rf /var/lib/apt/lists/*

# ── Backport gfx900 tensile libraries from ROCm 6.3.4 ────────────────────────
#
#  ROCm 7.x ships rocBLAS compiled without gfx900 tensile kernels.
#  We copy the gfx900 .co kernel files + TensileLibrary_lazy_gfx900.dat
#  directly from the ROCm 6.3.4 image (multi-stage) into the ROCm 7 library
#  path.  rocBLAS probes /opt/rocm/lib/rocblas/library/ at runtime and will
#  pick up the gfx900 kernels automatically.
#
COPY --from=rocm6-libs /opt/rocm/lib/rocblas/library/ /tmp/rocm6-rocblas/

RUN set -eux; \
    ROCM7_LIB="/opt/rocm/lib/rocblas/library"; \
    echo "ROCm 6.3.4 rocblas library contents (gfx900):"; \
    ls /tmp/rocm6-rocblas/ | grep -i gfx900 || echo "  (none with gfx900 in name)"; \
    # Copy all gfx900 .co kernel files \
    find /tmp/rocm6-rocblas -name '*gfx900*' | while read f; do \
        echo "  Copying: $(basename $f)"; \
        cp "$f" "$ROCM7_LIB/"; \
    done; \
    # Install TensileLibrary_lazy_gfx900.dat \
    GFX900_LAZY="$ROCM7_LIB/TensileLibrary_lazy_gfx900.dat"; \
    if [ ! -f "$GFX900_LAZY" ]; then \
        SRC="$(find /tmp/rocm6-rocblas -name 'TensileLibrary_lazy_gfx900.dat' | head -1)"; \
        if [ -z "$SRC" ]; then \
            SRC="$(find /tmp/rocm6-rocblas -name 'TensileLibrary.dat' | head -1)"; \
            echo "  Using TensileLibrary.dat as TensileLibrary_lazy_gfx900.dat"; \
        fi; \
        if [ -n "$SRC" ]; then \
            cp "$SRC" "$GFX900_LAZY"; \
            echo "  Installed: TensileLibrary_lazy_gfx900.dat  ($(du -sh "$GFX900_LAZY" | cut -f1))"; \
        else \
            echo "  WARNING: no TensileLibrary*.dat found in ROCm 6.3.4!"; \
        fi; \
    fi; \
    echo "=== ROCm 7 rocblas library (gfx900 files) ==="; \
    ls "$ROCM7_LIB" | grep -i gfx900 || echo "  WARNING: still no gfx900 files!"; \
    rm -rf /tmp/rocm6-rocblas; \
    echo "=== gfx900 tensile backport complete ==="

# ── Clone llama.cpp ───────────────────────────────────────────────────────────
WORKDIR /app
RUN git clone --depth 1 https://github.com/ggml-org/llama.cpp.git .

# ── Build with HIP targeting gfx900 ──────────────────────────────────────────
#
#  ROCm 7 HIP >= 6.1 so no version-check patch needed.
#  ROCm 7 HIP has native FP8 types — no FP8 typedef stub patch needed.
#  Code object version: ROCm 7 LLVM defaults to COv6; runtime supports it.
#
RUN cmake -B build \
      -DGGML_HIP=ON \
      -DAMDGPU_TARGETS="gfx900" \
      -DCMAKE_BUILD_TYPE=Release \
      -DGGML_HIP_GRAPHS=OFF \
      -DGGML_HIP_UMA=ON \
      -DGGML_FLASH_ATTN=ON \
      -DGGML_BACKEND_DL=ON \
      -DGGML_CPU_ALL_VARIANTS=ON \
      -DLLAMA_BUILD_SERVER=ON \
      -DLLAMA_BUILD_EXAMPLES=ON && \
    cmake --build build --config Release -j$(nproc)

# ── ROCm / HSA environment for Vega 8 iGPU ───────────────────────────────────
# gfx90c (Vega 8 APU) is closest to gfx900; override so HSA runtime accepts it
# ROCR/HIP_VISIBLE_DEVICES=0: expose only the first (Vega 8) GPU agent.
# run-docker-rocm7.sh passes only the Vega 8 /dev/dri/renderD* node into the
# container, so device 0 is always the iGPU, never the Radeon 9700 dGPU.
ENV ROCR_VISIBLE_DEVICES=0
ENV HIP_VISIBLE_DEVICES=0
ENV HSA_OVERRIDE_GFX_VERSION=9.0.0
# Disable SDMA engine — known to cause hangs on APU memory topology
ENV HSA_ENABLE_SDMA=0
# XNACK=0: prevents PC hang / system freeze on Vega 8 iGPU
ENV HSA_XNACK=0
# UMA=0: with XNACK=0 disabled, UMA page-fault handling causes segfaults
ENV GGML_HIP_UMA=0
# Allow GPU to use up to 100% of its visible VRAM (shared system RAM on APU)
ENV GPU_MAX_ALLOC_PERCENT=100
ENV GPU_SINGLE_ALLOC_PERCENT=100
ENV GPU_MAX_HEAP_SIZE=100
ENV GPU_FORCE_64BIT_PTR=1

EXPOSE 8080
ENTRYPOINT ["/app/build/bin/llama-server"]
