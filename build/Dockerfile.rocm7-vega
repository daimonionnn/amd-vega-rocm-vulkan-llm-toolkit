# ─────────────────────────────────────────────────────────────────────────────
#  llama.cpp  ·  ROCm 7.2  ·  AMD Vega 8 iGPU  (gfx902 / gfx909 / gfx90c)
# ─────────────────────────────────────────────────────────────────────────────
#
#  EXPERIMENTAL — ROCm 7.x officially dropped gfx900-family support.
#  This Dockerfile reinstates it by backporting the gfx900 tensile libraries
#  from ROCm 6.3.4 into the ROCm 7.2 rocBLAS install, mirroring the technique
#  used by garymathews/frigate:440056a-rocm-7.2.0 for MIGraphX / Frigate NVR.
#
#  Technique source:
#    https://github.com/garymathews/frigate/releases/tag/440056a-rocm-7.2.0
#    https://github.com/garymathews/AMDMIGraphX/blob/rocm-7.2.0/Dockerfile
#
#  Host requirements (same as ROCm 6 Docker setup):
#    --device=/dev/kfd  --device=/dev/dri  --group-add=video --group-add=render
#
#  Build:
#    docker build -t llama-rocm7-vega -f Dockerfile.rocm7-vega .
#
#  Run (use run-docker-rocm7.sh wrapper):
#    ./run-docker-rocm7.sh /path/to/model.gguf
#
# ─────────────────────────────────────────────────────────────────────────────

FROM rocm/dev-ubuntu-22.04:7.2

# ── Build tools + ROCm HIP/BLAS dev headers ──────────────────────────────────
RUN apt-get update -qq && \
    apt-get install -y -qq --no-install-recommends \
      build-essential \
      cmake \
      git \
      curl \
      wget \
      python3 \
      libomp-dev \
      hipblas-dev \
      rocblas-dev \
      rocsolver-dev \
      software-properties-common \
      gnupg2 \
      dpkg-dev && \
    rm -rf /var/lib/apt/lists/*

# ── Backport gfx900 tensile libraries from ROCm 6.3.4 ────────────────────────
#
#  ROCm 7.x ships rocBLAS compiled without gfx900 tensile kernels.
#  We fetch the rocBLAS package from the ROCm 6.3.4 repo, extract only the
#  prebuilt gfx900 .co (code-object) kernel files, and drop them into the
#  ROCm 7 library search path.  rocBLAS probes /opt/rocm/lib/rocblas/library/
#  at runtime and will pick up the gfx900 kernels automatically.
#
#  This is the same trick garymathews used for Frigate — credits to him for
#  discovering it works across major ROCm versions.
#
RUN set -eux; \
    # Add ROCm 6.3.4 apt repo (jammy) temporarily \
    curl -sL https://repo.radeon.com/rocm/rocm.gpg.key | apt-key add -; \
    echo "deb [arch=amd64] https://repo.radeon.com/rocm/apt/6.3.4 jammy main" \
        > /etc/apt/sources.list.d/rocm634.list; \
    apt-get update -qq; \
    # Download the rocblas .deb without installing it (would clash with rocm7) \
    mkdir -p /tmp/rocblas634 && cd /tmp/rocblas634; \
    apt-get download rocblas 2>/dev/null || \
        apt-get download "$(apt-cache show rocblas | grep '^Package' | awk '{print $2}')"; \
    # Extract package contents \
    dpkg-deb -x rocblas_*.deb /tmp/rocblas634/extracted; \
    # Copy only gfx900 code objects into ROCm 7 library path \
    ROCM7_LIB_PATH="$(find /opt/rocm-* -maxdepth 3 -type d -name library 2>/dev/null | head -1)"; \
    echo "Target rocBLAS library path: $ROCM7_LIB_PATH"; \
    find /tmp/rocblas634/extracted -name '*gfx900*' | while read f; do \
        echo "  Copying: $(basename $f)"; \
        cp "$f" "$ROCM7_LIB_PATH/"; \
    done; \
    # Clean up — remove the 6.3.4 repo so it doesn't interfere with anything \
    rm /etc/apt/sources.list.d/rocm634.list; \
    apt-get update -qq; \
    rm -rf /tmp/rocblas634; \
    echo "=== gfx900 tensile backport complete ==="

# ── Clone llama.cpp ───────────────────────────────────────────────────────────
WORKDIR /app
RUN git clone --depth 1 https://github.com/ggml-org/llama.cpp.git .

# ── Build with HIP targeting gfx900 ──────────────────────────────────────────
#
#  ROCm 7 HIP >= 6.1 so no version-check patch needed.
#  ROCm 7 HIP has native FP8 types — no FP8 typedef stub patch needed.
#  Code object version: ROCm 7 LLVM defaults to COv6; runtime supports it.
#
RUN cmake -B build \
      -DGGML_HIP=ON \
      -DAMDGPU_TARGETS="gfx900" \
      -DCMAKE_BUILD_TYPE=Release \
      -DGGML_HIP_UMA=ON \
      -DGGML_FLASH_ATTN=ON \
      -DLLAMA_BUILD_SERVER=ON \
      -DLLAMA_BUILD_EXAMPLES=ON && \
    cmake --build build --config Release -j$(nproc)

# ── ROCm / HSA environment for Vega 8 iGPU ───────────────────────────────────
# gfx90c (Vega 8 APU) is closest to gfx900; override so HSA runtime accepts it
# ROCR/HIP_VISIBLE_DEVICES=0: expose only the first (Vega 8) GPU agent.
# run-docker-rocm7.sh passes only the Vega 8 /dev/dri/renderD* node into the
# container, so device 0 is always the iGPU, never the Radeon 9700 dGPU.
ENV ROCR_VISIBLE_DEVICES=0
ENV HIP_VISIBLE_DEVICES=0
ENV HSA_OVERRIDE_GFX_VERSION=9.0.0
# Disable SDMA engine — known to cause hangs on APU memory topology
ENV HSA_ENABLE_SDMA=0
# XNACK=0: prevents PC hang / system freeze on Vega 8 iGPU
ENV HSA_XNACK=0
# UMA=0: with XNACK=0 disabled, UMA page-fault handling causes segfaults
ENV GGML_HIP_UMA=0
# Allow GPU to use up to 100% of its visible VRAM (shared system RAM on APU)
ENV GPU_MAX_ALLOC_PERCENT=100
ENV GPU_SINGLE_ALLOC_PERCENT=100
ENV GPU_MAX_HEAP_SIZE=100
ENV GPU_FORCE_64BIT_PTR=1

EXPOSE 8080
ENTRYPOINT ["/app/build/bin/llama-server"]
