FROM rocm/dev-ubuntu-24.04:6.2.4

RUN apt-get update -qq && \
    apt-get install -y -qq --no-install-recommends \
      build-essential cmake git curl python3 libomp-dev \
      hipblas-dev rocblas-dev rocsolver-dev numactl && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app
RUN git clone https://github.com/ggml-org/llama.cpp.git .

# Patch: gfx900 (Vega) does not support FP8. vendors/hip.h unconditionally
# typedef-aliases CUDA FP8 types to HIP FP8 types, which don't exist on gfx900.
# Replace each FP8 typedef with a plain stub struct so the code compiles on gfx900.
RUN for HIP_FP8 in __hip_fp8_e4m3 __hip_fp8_e5m2 __hip_fp8_e4m3_fnuz __hip_fp8_e5m2_fnuz; do \
      NV_FP8=$(echo "$HIP_FP8" | sed 's/__hip_/__nv_/'); \
      sed -i "s|typedef ${HIP_FP8} ${NV_FP8};|struct ${NV_FP8} { unsigned char data; };|g" \
        ggml/src/ggml-cuda/vendors/hip.h; \
    done && echo 'FP8 typedef patch applied'

# GGML_FLASH_ATTN is not a llama.cpp CMake option (FA is the runtime -fa
# flag). GPU_TARGETS replaces the deprecated AMDGPU_TARGETS spelling.
RUN cmake -B build \
      -DGGML_HIP=ON \
      -DGPU_TARGETS="gfx900" \
      -DCMAKE_BUILD_TYPE=Release \
      -DGGML_HIP_GRAPHS=OFF \
      -DGGML_BACKEND_DL=ON \
      -DGGML_CPU_ALL_VARIANTS=ON && \
    cmake --build build --config Release -j$(nproc)

# ROCm environment for Vega 8 APU
# ROCR/HIP_VISIBLE_DEVICES=0: expose only the first GPU agent (Vega 8 iGPU).
# run-docker-rocm.sh passes only the Vega 8 /dev/dri/renderD* node into the
# container, so device 0 is always the iGPU, never the Radeon 9700 dGPU.
ENV ROCR_VISIBLE_DEVICES=0
ENV HIP_VISIBLE_DEVICES=0
ENV HSA_OVERRIDE_GFX_VERSION=9.0.0
ENV HSA_ENABLE_SDMA=0
# HSA_XNACK=0: prevents PC hang on Vega 8 iGPU (XNACK=1 freezes whole system)
ENV HSA_XNACK=0
ENV GPU_MAX_ALLOC_PERCENT=100
ENV GPU_SINGLE_ALLOC_PERCENT=100
ENV GPU_MAX_HEAP_SIZE=100
ENV GPU_FORCE_64BIT_PTR=1

EXPOSE 8080
ENTRYPOINT ["/app/build/bin/llama-server"]
